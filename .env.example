# === Credentials ===
WANDB_API_KEY=
HF_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Hardware-dependent knobs (portability_guide.md 표 참조) ===
# 4060 8GB default
BATCH_SIZE=4
GRAD_ACCUM_STEPS=8
MIXED_PRECISION=fp16      # no | fp16 | bf16
LOAD_IN_4BIT=true
MAX_SEQ_LEN=1024
NUM_WORKERS=2

# === Training defaults ===
EPOCHS=1
LR=1e-3

# === Paths ===
DATA_DIR=./data
CKPT_DIR=./experiments

# === Time budget gate (scripts/time_probe.py, docs/time_budgeting.md) ===
# Hackathon start time, ISO format. e.g. 2026-07-19T09:00:00
HACKATHON_START=
